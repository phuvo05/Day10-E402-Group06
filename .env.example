# Day 10 Lab — copy thành .env và điền nếu cần
#   cp .env.example .env

# ChromaDB (khuyến nghị tách collection khỏi Day 09)
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day10_kb

# Embedding — SentenceTransformers (offline, mặc định)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenAI embedding (ưu tiên hơn SentenceTransformers nếu có API key)
# Model: text-embedding-3-small (1536 dim) hoặc text-embedding-3-large (3072 dim)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Freshness SLA (giờ) — dùng trong monitoring/freshness_check.py
FRESHNESS_SLA_HOURS=24
